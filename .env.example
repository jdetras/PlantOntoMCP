# OntoMCP environment variables — copy to .env and edit

# --- Core ---
ONTOMCP_DB_PATH=~/.ontomcp/cache.db         # SQLite cache file path
ONTOMCP_LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# --- Crop Ontology (AgroPortal) — OPTIONAL ---
# The Crop Ontology (CO_320 Rice, CO_321 Wheat, …) is served by AgroPortal, which
# requires a free API key (https://agroportal.eu/account). Leave unset to skip CO;
# every EBI OLS4 ontology (PO, TO, GO, …) works without it.
# AGROPORTAL_API_KEY=your-agroportal-api-key

# --- FastAPI server ---
ONTOMCP_API_HOST=127.0.0.1                   # loopback by default; set to 0.0.0.0 to expose on the network
ONTOMCP_API_PORT=8000                        # REST API port

# --- FastMCP server ---
# Set to "sse" for GPT, Codex CLI, and remote MCP clients.
# Leave as "stdio" (default) for Claude Desktop and Claude Code.
ONTOMCP_TRANSPORT=stdio
ONTOMCP_MCP_HOST=127.0.0.1                    # set to 0.0.0.0 to expose on the network
ONTOMCP_MCP_PORT=8001                         # only used when TRANSPORT=sse
